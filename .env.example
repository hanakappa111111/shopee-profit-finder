# ── Copy to .env and fill in your values ─────────────────────────────────────
# cp .env.example .env

# OpenAI (required for AI title/description/keyword generation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Shopee Partner API (required for posting/managing listings)
# Get credentials at: https://open.shopee.com/
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_MARKET=PH          # PH | SG | MY

# Scheduler times (24h local time)
MARKET_ANALYSIS_TIME=02:00
PIPELINE_SCHEDULE_TIME=02:00

# Profit thresholds
MIN_PROFIT_YEN=2000
MIN_ROI_PERCENT=30.0
MIN_MATCH_SIMILARITY=70.0

# Winning product thresholds
MIN_SALES_COUNT=200
MIN_RATING=4.5
MIN_PRICE_PHP=800.0

# Price optimiser
PRICE_UNDERCUT_PERCENT=3.0
MIN_MARGIN_PHP=200.0

# Logging
LOG_LEVEL=INFO
